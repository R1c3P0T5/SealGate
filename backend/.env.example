# Backend Configuration
# Copy to .env and fill in values

# Generate with: openssl rand -hex 32
SECRET_KEY=<run: openssl rand -hex 32>

# Docker deployment (named volume)
DATABASE_URL=sqlite+aiosqlite:////app/data/sealgate.db

DEBUG=False

# Face recognition model paths (relative to backend/ working directory)
# FACE_DETECTOR_MODEL=models/face_detection_yunet_2023mar.onnx
# FACE_RECOGNIZER_MODEL=models/face_recognition_sface_2021dec.onnx
# COSINE_THRESHOLD=0.363

# MQTT broker and door unlock command settings
# MQTT_HOST=localhost
# MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_UNLOCK_TOPIC_TEMPLATE=doors/{mqtt_id}/unlock
# MQTT_UNLOCK_PAYLOAD=unlock

# Default admin account
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=<set-a-strong-password>
# DEFAULT_ADMIN_FULL_NAME=Administrator
# DEFAULT_ADMIN_EMAIL=admin@example.com
