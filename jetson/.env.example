# Worker Configuration
# Copy to .env and fill in values

# Backend server address (replace with actual server IP or hostname)
BACKEND_URL=http://backend:8000
BACKEND_WS_URL=ws://backend:8000

# Door identity (obtain from the web UI after creating a Door and Device)
DOOR_ID=<uuid-from-web-ui-door-page>
DEVICE_TOKEN=<one-time-token-from-device-create-or-rotate>

# Camera settings
CAMERA_INDEX=0
JPEG_QUALITY=70
STREAM_FPS=20
DETECT_FPS=10

# Recognition tuning
RECOGNIZE_MIN_INTERVAL_SECONDS=0.5
RECOGNIZE_SUCCESS_COOLDOWN_SECONDS=3.0
RECOGNIZE_FAILURE_COOLDOWN_SECONDS=0.5
MAX_RECOGNIZE_IN_FLIGHT=1
CAMERA_FAIL_RETRY=30

FACE_DETECTOR_MODEL=models/face_detection_yunet_2023mar.onnx
